/* ---------- kazetový strop 60×120 (realistický: kazeta + T-profil 24 mm) ---------- */
function stropTexFn(o){ // o = {kazeta, sum, sumA, profil, profilHi, stin}
  const c=document.createElement('canvas'); c.width=240; c.height=120; const x=c.getContext('2d');
  x.fillStyle=o.kazeta; x.fillRect(0,0,240,120);
  // jemná struktura minerální kazety (tečkovaný vpich)
  for(let i=0;i<420;i++){
    x.fillStyle=`rgba(${o.sum},${(0.03+Math.random()*o.sumA).toFixed(3)})`;
    x.fillRect(Math.random()*240, Math.random()*120, 1.4, 1.4);
  }
  // stín kazety u profilu (kazeta je zapuštěná)
  x.strokeStyle=o.stin; x.lineWidth=7; x.strokeRect(3.5,3.5,233,113);
  // T-profil (mírně zvýrazněný, ať je rastr čitelný i z dálky)
  x.strokeStyle=o.profil; x.lineWidth=6; x.strokeRect(0,0,240,120);
  // odlesk středu profilu (lesklý lak na T-liště)
  x.strokeStyle=o.profilHi; x.lineWidth=2.5; x.strokeRect(1.2,1.2,237.6,117.6);
  /* ShapeGeometry má UV v metrech → 1 dlaždice textury = 1,2 × 0,6 m (kazeta 120×60) */
  const t=new THREE.CanvasTexture(c); t.wrapS=t.wrapT=THREE.RepeatWrapping; t.repeat.set(1/1.2, 1/0.6); t.anisotropy=16; t.colorSpace=THREE.SRGBColorSpace; return t;
}
