/* vestavěná nika (š 1,6 × hl 0,45 × v 2,3) — police / tyč / kombinace, s LED podsvícením */
function nika(o){
  const g=new THREE.Group();
  const W=Math.max(0.6,Math.min(4,o.w||1.6)), D=0.45, V=2.3, R=0.08;
  // OBLOŽENÍ TRAVERTINEM (jako pevná nika-stěna): líc/boky/strop/sokl travertin, police ořech, tyč mosaz
  const zad=new THREE.Mesh(new THREE.BoxGeometry(W-2*R,V-2*R,0.03),M.travertin); zad.position.set(0,V/2,-D/2+0.015); g.add(zad);
  [-1,1].forEach(s=>{ const bok=new THREE.Mesh(new THREE.BoxGeometry(R,V,D),M.travertin); bok.position.set(s*(W/2-R/2),V/2,0); g.add(bok); });
  const top=new THREE.Mesh(new THREE.BoxGeometry(W,R,D),M.travertin); top.position.set(0,V-R/2,0); g.add(top);
  const sokl=new THREE.Mesh(new THREE.BoxGeometry(W-2*R,0.12,D-0.06),M.travertin); sokl.position.set(0,0.06,0); g.add(sokl);
  const ledMat=new THREE.MeshStandardMaterial({ color:0xffd9a8, emissive:0xffd9a8, emissiveIntensity:1.5 });
  const led=new THREE.Mesh(new THREE.BoxGeometry(W-2*R-0.04,0.012,0.025),ledMat); led.position.set(0,V-R-0.01,D/2-0.1); g.add(led);
  (o.police||[]).forEach(y=>{ const p=new THREE.Mesh(new THREE.BoxGeometry(W-2*R-0.02,0.035,D-0.1),M.orech); p.position.set(0,y,0.01); g.add(p); });
  if(o.tyc){ const t=new THREE.Mesh(new THREE.CylinderGeometry(0.013,0.013,W-2*R-0.04,12),M.mosaz);
    t.rotation.z=Math.PI/2; t.position.set(0,o.tyc,0.02); g.add(t);
    obleceni(g,o.tyc,W-2*R-0.2,Math.max(3,Math.round((W-0.4)/0.45)),0.02); }
  return shadowAll(g);
}
function obleceni(g, y, w, n, z0=0){
  for(let i=0;i<n;i++){
    const c=new THREE.MeshStandardMaterial({ color:OBLEKY[i%OBLEKY.length], roughness:0.92 });
    const o=new THREE.Mesh(new THREE.BoxGeometry(0.04,0.62,0.42),c);
    o.position.set(-w/2+0.12+i*(w-0.24)/Math.max(1,n-1), y-0.34, z0); g.add(o);
    const ram=new THREE.Mesh(new THREE.CylinderGeometry(0.004,0.004,0.18,6),M.kov);
    ram.rotation.z=Math.PI/2; ram.position.set(o.position.x, y-0.015, z0); g.add(ram);
  }
}
