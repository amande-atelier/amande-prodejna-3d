/* ===================================================================
   PŘEDSAZENÁ STĚNA S OSVĚTLENÝMI NIKAMI (podél osy sloupů, líc do interiéru +x)
   Schová 3 sloupy do plných pilířů; poslední pole (za posledním sloupem) plné.
   =================================================================== */
const nikaStenaRoot = new THREE.Group(); scene.add(nikaStenaRoot);
const nikaSvetla = [];
function postavNikaStenu(){
  vycisti(nikaStenaRoot);
  nikaSvetla.length=0;
  const cols=[3.5,7.1,10.7];   // sloupy 13×13 cm, x=3,1 (osa)
  const xFace=3.58;            // líc stěny (do interiéru)
  const dRecess=0.40;          // hloubka niky (40 cm — na ramínka)
  const xNal=xFace-dRecess;    // zadní stěna niky = 3,18 (těsně před sloupem 3,165)
  const dWall=0.58;            // celková hloubka konstrukce (schová sloup 13 cm za nikou)
  const xBack=xFace-dWall;     // 3,00 (za sloupem)
  const xMid=(xFace+xBack)/2, depthFull=dWall;
  const wallTop=H-0.08;        // stěna končí 8 cm pod stropem → nahoře STÍNOVÁ SPÁRA
  const zStart=1.9, zEnd=ROOM.hloubka;
  const parapet=0.30, nadpr=2.45;          // otvor niky 0,30–2,45 m
  const pierHalf=0.16;                       // pilíř 32 cm (sloup 13 + rám + OSB + panel)
  const lic=M.travertin, vnitr=M.travertin;

  // box líce (plné pole) v rozsahu z0..z1, do výšky wallTop
  function plnePole(z0,z1){
    if(z1-z0<0.005) return;
    const b=new THREE.Mesh(new THREE.BoxGeometry(depthFull,wallTop,z1-z0),lic);
    b.position.set(xMid,wallTop/2,(z0+z1)/2); b.castShadow=true; b.receiveShadow=true; nikaStenaRoot.add(b);
  }
  // nika v rozsahu z0..z1
  function nika(z0,z1){
    const w=z1-z0, zc=(z0+z1)/2;
    // parapet (pod otvorem) a nadpraží (nad otvorem) — plná hloubka
    const par=new THREE.Mesh(new THREE.BoxGeometry(depthFull,parapet,w),lic); par.position.set(xMid,parapet/2,zc); nikaStenaRoot.add(par);
    const nad=new THREE.Mesh(new THREE.BoxGeometry(depthFull,wallTop-nadpr,w),lic); nad.position.set(xMid,(wallTop+nadpr)/2,zc); nikaStenaRoot.add(nad);
    // záda niky
    const zad=new THREE.Mesh(new THREE.BoxGeometry(xNal-xBack,nadpr-parapet,w),vnitr); zad.position.set((xNal+xBack)/2,(parapet+nadpr)/2,zc); nikaStenaRoot.add(zad);
    nikaStenaRoot.traverse(o=>{ if(o.isMesh){o.castShadow=true;o.receiveShadow=true;} });
    // police z masivního ořechu (horní třetina otvoru), přes celou šířku
    const yShelf=parapet+(nadpr-parapet)*0.66;
    const pol=new THREE.Mesh(new THREE.BoxGeometry(dRecess-0.02,0.04,w-0.04),M.orech);
    pol.position.set(xNal+dRecess/2,yShelf,zc); pol.castShadow=true; nikaStenaRoot.add(pol);
    // mosazná tyč pod policí, přes celou šířku + středová konzola
    const yRod=yShelf-0.16;
    const tyc=new THREE.Mesh(new THREE.CylinderGeometry(0.014,0.014,w-0.06,12),M.mosaz);
    tyc.rotation.x=Math.PI/2; tyc.position.set(xNal+dRecess*0.55,yRod,zc); nikaStenaRoot.add(tyc);
    const konz=new THREE.Mesh(new THREE.BoxGeometry(0.03,0.10,0.02),M.mosaz); konz.position.set(xNal+dRecess*0.55,yRod+0.05,zc); nikaStenaRoot.add(konz);
    // oblečení na tyči (náznak)
    const barvy=[0x2a2a30,0x8c7a5b,0xb8b3a8,0x6e4a3a,0x55585f];
    const n=Math.max(2,Math.round(w/0.32));
    for(let i=0;i<n;i++){ const o=new THREE.Mesh(new THREE.BoxGeometry(dRecess*0.5,0.55,0.05),
        new THREE.MeshStandardMaterial({color:barvy[i%barvy.length],roughness:0.92}));
      o.position.set(xNal+dRecess*0.55,yRod-0.32,z0+0.12+i*(w-0.24)/Math.max(1,n-1)); o.castShadow=true; nikaStenaRoot.add(o); }
    // skrytý LED v horním lemu niky (svítí dolů) + pásek pod policí
    const ledMat=new THREE.MeshStandardMaterial({color:0xffe8c6,emissive:0xffd9a8,emissiveIntensity:2.2});
    const lemTop=new THREE.Mesh(new THREE.BoxGeometry(0.02,0.02,w-0.06),ledMat); lemTop.position.set(xFace-0.04,nadpr-0.04,zc); nikaStenaRoot.add(lemTop);
    const lemPol=new THREE.Mesh(new THREE.BoxGeometry(0.02,0.012,w-0.08),ledMat); lemPol.position.set(xNal+dRecess*0.8,yShelf-0.03,zc); nikaStenaRoot.add(lemPol);
    // měkké teplé světlo dovnitř niky
    const sv=new THREE.PointLight(0xffd9a8,0,3.0,1.8); sv.position.set(xNal+0.2,nadpr-0.2,zc);
    nikaStenaRoot.add(sv); nikaSvetla.push(sv);
  }

  // pilíře jen u sloupů; PRŮCHOD před 1. sloupem (1. nika zrušena) a STĚNA KONČÍ U POSLEDNÍHO SLOUPU
  const solids=[];
  cols.forEach(c=>solids.push([c-pierHalf,c+pierHalf]));
  const wallStart = cols[0]-pierHalf, wallEnd = cols[2]+pierHalf;
  // vykresli pevné zóny (pilíře u sloupů)
  solids.forEach(s=>plnePole(s[0],s[1]));
  // mezi pevnými zónami = JEDNA nika na pole (předěl jen tam, kde reálně stojí sloup) → 3 niky
  for(let i=0;i<solids.length-1;i++){
    const a=solids[i][1], b=solids[i+1][0]; const span=b-a;
    if(span<0.4){ if(span>0.01) plnePole(a,b); continue; }
    nika(a,b);
  }
  // ZADNÍ STRANA STĚNY: mosazné tyče na věšení (po celé délce, mezi pilíři)
  const yRod2=1.75, xRod=xBack-0.16, barvy2=[0x2a2a30,0x8c7a5b,0xb8b3a8,0x6e4a3a,0x55585f,0x7c2730];
  for(let i=0;i<solids.length-1;i++){
    const a=solids[i][1], b=solids[i+1][0], L=b-a; if(L<0.4) continue;
    const zc=(a+b)/2;
    const tyc=new THREE.Mesh(new THREE.CylinderGeometry(0.016,0.016,L-0.06,12),M.mosaz);
    tyc.rotation.x=Math.PI/2; tyc.position.set(xRod,yRod2,zc); nikaStenaRoot.add(tyc);
    [a+0.05,b-0.05].forEach(z=>{ const k=new THREE.Mesh(new THREE.BoxGeometry(0.16,0.022,0.022),M.mosaz);
      k.position.set((xBack+xRod)/2,yRod2,z); nikaStenaRoot.add(k); });          // konzoly do stěny
    const stred=new THREE.Mesh(new THREE.BoxGeometry(0.16,0.022,0.022),M.mosaz); stred.position.set((xBack+xRod)/2,yRod2,zc); nikaStenaRoot.add(stred);
    const n=Math.max(3,Math.round(L/0.30));
    for(let j=0;j<n;j++){ const o=new THREE.Mesh(new THREE.BoxGeometry(0.06,0.6,0.4),
        new THREE.MeshStandardMaterial({color:barvy2[j%barvy2.length],roughness:0.92}));
      o.position.set(xRod-0.03,yRod2-0.36,a+0.12+j*(L-0.24)/Math.max(1,n-1)); o.castShadow=true; nikaStenaRoot.add(o); }
  }
  // podsvícený sokl u podlahy + horní omývání stěny (ambient) — po délce stěny
  const soklMat=new THREE.MeshStandardMaterial({color:0xffe8c6,emissive:0xffd9a8,emissiveIntensity:1.4});
  const sokl=new THREE.Mesh(new THREE.BoxGeometry(0.015,0.05,wallEnd-wallStart),soklMat); sokl.position.set(xFace-0.02,0.06,(wallStart+wallEnd)/2); nikaStenaRoot.add(sokl);
  const lemHorni=new THREE.Mesh(new THREE.BoxGeometry(0.015,0.04,wallEnd-wallStart),soklMat); lemHorni.position.set(xFace-0.02,wallTop-0.04,(wallStart+wallEnd)/2); nikaStenaRoot.add(lemHorni);
}

/* ---------- ALT: HŘEBEN — 3 kolmé stěny od levé zdi ke sloupům, mezi nimi 2 boxy (dle náčrtku) ---------- */
function postavHreben(){
  vycisti(nikaStenaRoot);
  nikaSvetla.length=0;
  const cols=[3.5,7.1,10.7];
  const xF=3.58, boxDepth=2.2, xBack=xF-boxDepth, tw=0.25;   // MĚLČÍ boxy 2,2 m; za nimi zůstane volná podlaha k levé zdi
  const wallTop=H-0.08;
  const led=new THREE.MeshStandardMaterial({color:0xffe8c6,emissive:0xffd9a8,emissiveIntensity:1.6});
  const barvy=[0x2a2a30,0x8c7a5b,0xb8b3a8,0x6e4a3a,0x55585f,0x7c2730];
  // zadní páteř spojující zuby (uzavírá boxy vzadu, drží konstrukci)
  const spine=new THREE.Mesh(new THREE.BoxGeometry(tw,wallTop,cols[2]-cols[0]+tw),M.travertin);
  spine.position.set(xBack,wallTop/2,(cols[0]+cols[2])/2); spine.castShadow=spine.receiveShadow=true; nikaStenaRoot.add(spine);
  // 3 zuby (kolmé stěny) — líc travertin
  cols.forEach(cz=>{
    const w=new THREE.Mesh(new THREE.BoxGeometry(boxDepth,wallTop,tw),M.travertin);
    w.position.set((xBack+xF)/2,wallTop/2,cz); w.castShadow=w.receiveShadow=true; nikaStenaRoot.add(w);
  });
  // 2 boxy: na obou lících tyč + oblečení + police + LED
  for(let i=0;i<cols.length-1;i++){
    [cols[i]+tw/2, cols[i+1]-tw/2].forEach((fz,side)=>{
      const dir = side===0 ? 1 : -1, cx=(xBack+xF)/2, rodLen=boxDepth-0.4;
      const tyc=new THREE.Mesh(new THREE.CylinderGeometry(0.016,0.016,rodLen,12),M.mosaz);
      tyc.rotation.z=Math.PI/2; tyc.position.set(cx,1.55,fz+dir*0.07); nikaStenaRoot.add(tyc);
      const pol=new THREE.Mesh(new THREE.BoxGeometry(rodLen,0.04,0.30),M.orech);
      pol.position.set(cx,1.95,fz+dir*0.16); pol.castShadow=true; nikaStenaRoot.add(pol);
      const l=new THREE.Mesh(new THREE.BoxGeometry(rodLen,0.02,0.02),led); l.position.set(cx,1.90,fz+dir*0.07); nikaStenaRoot.add(l);
      for(let k=0;k<4;k++){ const o=new THREE.Mesh(new THREE.BoxGeometry(0.05,0.55,0.36),
        new THREE.MeshStandardMaterial({color:barvy[(k+i+side)%barvy.length],roughness:0.9}));
        o.position.set(xBack+0.3+k*rodLen/3,1.22,fz+dir*0.07); o.castShadow=true; nikaStenaRoot.add(o); }
    });
    const sv=new THREE.PointLight(0xffd9a8,3,4.5,2); sv.position.set((xBack+xF)/2,2.4,(cols[i]+cols[i+1])/2);
    nikaStenaRoot.add(sv); nikaSvetla.push(sv);
  }
  // podsvícený sokl u sloupové linie (líc do prodejny)
  const soklMat=new THREE.MeshStandardMaterial({color:0xffe8c6,emissive:0xffd9a8,emissiveIntensity:1.4});
  cols.forEach(cz=>{ const s=new THREE.Mesh(new THREE.BoxGeometry(0.05,0.05,tw),soklMat); s.position.set(xF-0.03,0.06,cz); nikaStenaRoot.add(s); });
  nikaStenaRoot.traverse(o=>{ if(o.isMesh){o.castShadow=true;o.receiveShadow=true;} });
}

