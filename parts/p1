function shapeFromPts(pts){ const s=new THREE.Shape(); s.moveTo(pts[0][0],pts[0][1]); for(let i=1;i<pts.length;i++) s.lineTo(pts[i][0],pts[i][1]); s.closePath(); return s; }

/* úklid GPU paměti: geometrie jsou v projektu vždy per-mesh → při odstranění je uvolníme
   (materiály jsou sdílené z M.* — ty NEuvolňovat!) */
function zahodGeometrie(o){ o.traverse(m=>{ if(m.isMesh&&m.geometry) m.geometry.dispose(); }); }
function vycisti(root){ while(root.children.length){ const ch=root.children[0]; zahodGeometrie(ch); root.remove(ch); } }

/* ===================================================================
   PODLAHA — malovatelná mřížka 0,5 m (dlažba/koberec/vinyl/stěrka)
   =================================================================== */
const GRID = 0.5, FC = Math.round(ROOM.celo/GRID), FR = Math.round(ROOM.hloubka/GRID); // 17 × 37
const CP_ = 24, FW = FC*CP_, FH = FR*CP_;
const fCan = document.createElement('canvas'); fCan.width=FW; fCan.height=FH;
const fCtx = fCan.getContext('2d');
const fTex = new THREE.CanvasTexture(fCan);
fTex.wrapS = fTex.wrapT = THREE.ClampToEdgeWrapping;
fTex.repeat.set(1/(FC*GRID), 1/(FR*GRID));
fTex.anisotropy = 8; fTex.colorSpace = THREE.SRGBColorSpace;

const MATY = [
  { id:0, nazev:'Dlažba béžová',   css:'#d9cdb8', rough:0.55 },
  { id:1, nazev:'Koberec antracit',css:'#47474b', rough:1.0 },
  { id:2, nazev:'Vinyl sv. dub',   css:'#b08e5f', rough:0.45 },
  { id:3, nazev:'Vinyl tm. dub',   css:'#6e4f33', rough:0.45 },
  { id:4, nazev:'Stěrka šedá',     css:'#9fa1a5', rough:0.7 },
];
function hash2(a,b){ let h=(a*73856093)^(b*19349663); h=(h^(h>>13))*1274126177; return ((h^(h>>16))>>>0)/4294967295; }
function shade(hex,f){ const r=Math.min(255,Math.max(0,((hex>>16)&255)*f)), g=Math.min(255,Math.max(0,((hex>>8)&255)*f)), b=Math.min(255,Math.max(0,(hex&255)*f));
  return `rgb(${r|0},${g|0},${b|0})`; }
function drawCell(ci,cj){
  const v = stav.podlaha[cj*FC+ci];
  const px = ci*CP_, py = FH-(cj+1)*CP_;
  fCtx.save(); fCtx.beginPath(); fCtx.rect(px,py,CP_,CP_); fCtx.clip();
  if(v===0){ // dlažba 1×1 m (rastr po 2 buňkách)
    const f = 0.97 + 0.06*hash2(ci>>1,cj>>1);
    fCtx.fillStyle = shade(0xd9cdb8,f); fCtx.fillRect(px,py,CP_,CP_);
    fCtx.strokeStyle='#c0b49c'; fCtx.lineWidth=2;
    if(ci%2===0){ fCtx.beginPath(); fCtx.moveTo(px+1,py); fCtx.lineTo(px+1,py+CP_); fCtx.stroke(); }
    if(cj%2===0){ fCtx.beginPath(); fCtx.moveTo(px,py+CP_-1); fCtx.lineTo(px+CP_,py+CP_-1); fCtx.stroke(); }
  } else if(v===1){ // koberec
    fCtx.fillStyle='#47474b'; fCtx.fillRect(px,py,CP_,CP_);
    for(let i=0;i<26;i++){ const r1=hash2(ci*31+i,cj*17+i), r2=hash2(cj*53+i,ci*7-i);
      fCtx.fillStyle = r1>0.5 ? '#4d4d52' : '#414146';
      fCtx.fillRect(px+r1*CP_, py+r2*CP_, 1.6, 1.6); }
  } else if(v===2||v===3){ // vinylové lamely podél hloubky (osa z)
    const base = v===2?0xb08e5f:0x6e4f33, PW=0.19, JL=1.22;
    const x0=ci*GRID, x1=x0+GRID;
    for(let pc=Math.floor(x0/PW); pc*PW<x1; pc++){
      const sx=Math.max(x0,pc*PW), ex=Math.min(x1,(pc+1)*PW);
      const off=(pc%4)*0.33;
      const z0=cj*GRID, z1=z0+GRID;
      let seg=Math.floor((z0+off)/JL);
      for(let zz=z0; zz<z1-1e-6;){
        const segEnd=(seg+1)*JL-off, ze=Math.min(z1,segEnd);
        const f=0.92+0.16*hash2(pc*7+1,seg*13+3);
        fCtx.fillStyle=shade(base,f);
        const rx=px+(sx-x0)/GRID*CP_, rw=(ex-sx)/GRID*CP_;
        const ryTop=py+(z1-ze)/GRID*CP_, rh=(ze-zz)/GRID*CP_;
        fCtx.fillRect(rx,ryTop,rw+0.5,rh+0.5);
        if(segEnd<z1){ fCtx.fillStyle=shade(base,0.72); fCtx.fillRect(rx,ryTop-0.7,rw,1.4); }
        zz=ze; seg++;
      }
      // podélná spára lamely
      if(sx===pc*PW){ fCtx.fillStyle=shade(base,0.74); fCtx.fillRect(px+(sx-x0)/GRID*CP_,py,1.2,CP_); }
    }
  } else { // stěrka
    const f=0.96+0.08*hash2(ci,cj);
    fCtx.fillStyle=shade(0x9fa1a5,f); fCtx.fillRect(px,py,CP_,CP_);
    for(let i=0;i<3;i++){ const r=hash2(ci*5+i,cj*9+i);
      fCtx.fillStyle=`rgba(${r>0.5?255:60},${r>0.5?255:60},${r>0.5?255:64},0.05)`;
      fCtx.beginPath(); fCtx.arc(px+hash2(i,ci+cj)*CP_, py+r*CP_, 6+8*r, 0, 7); fCtx.fill(); }
  }
  fCtx.restore();
}
function redrawFloor(){ for(let j=0;j<FR;j++) for(let i=0;i<FC;i++) drawCell(i,j); fTex.needsUpdate=true; }

function inPoly(x,z,poly){ let inside=false;
  for(let i=0,j=poly.length-1;i<poly.length;j=i++){
    const xi=poly[i][0],zi=poly[i][1],xj=poly[j][0],zj=poly[j][1];
    if(((zi>z)!==(zj>z)) && (x < (xj-xi)*(z-zi)/(zj-zi)+xi)) inside=!inside; }
  return inside; }
const PRESETY = {
  stavajici(){ stav.podlaha.fill(0); },   // stávající stav: dlažba (zóny si Frederik domaluje)
  vinyl(){ stav.podlaha.fill(2); },
  vinylTmavy(){ stav.podlaha.fill(3); },
  vinylKob(){ for(let j=0;j<FR;j++) for(let i=0;i<FC;i++) stav.podlaha[j*FC+i] = (j*GRID>ROOM.hloubka-4.5)?1:2; },
};

const podlahaMat = new THREE.MeshStandardMaterial({ map:fTex, color:0xffffff, roughness:0.6, side:THREE.DoubleSide });
const podlaha = new THREE.Mesh(new THREE.ShapeGeometry(shapeFromPts(obrys)), podlahaMat);
podlaha.rotation.x = Math.PI/2; podlaha.receiveShadow=true; room.add(podlaha);

/* ---------- stěny (editovatelné: výlohy + dveře) ---------- */
function stena(p1,p2,mat,h=H,tl=T,y0=0,parent=room){
  const dx=p2[0]-p1[0], dz=p2[1]-p1[1], len=Math.hypot(dx,dz);
  const m=new THREE.Mesh(new THREE.BoxGeometry(len,h,tl),mat);
  m.position.set((p1[0]+p2[0])/2, y0+h/2, (p1[1]+p2[1])/2); m.rotation.y=-Math.atan2(dz,dx);
  m.castShadow=true; m.receiveShadow=true; parent.add(m); return m;
}
/* definice editovatelných stěn: p1→p2, pozice prvku = metry od p1 (střed prvku) */
const STENY = {
  C: { p1:P.CL, p2:P.CP, nazev:'horní stěna' },     // 3,6 m (výloha 3,4)
  P: { p1:P.CP, p2:P.ZP, nazev:'pravá stěna' },      // 15,6 m (výloha 3,0)
  Z: { p1:P.ZL, p2:P.ZP, nazev:'spodní stěna' },     // 8,9 m (2× dveře)
  L: { p1:P.ZL, p2:P.VL, nazev:'levá stěna' },       // 13,8 m
  N: { p1:P.VL, p2:P.VR, nazev:'stěna výklenku' },   // 5,3 m (skleněné dveře)
  VB:{ p1:P.VR, p2:P.CL, nazev:'prosklený schod' },  // 1,8 m (sklo do stropu)
};
Object.values(STENY).forEach(s=>{
  const dx=s.p2[0]-s.p1[0], dz=s.p2[1]-s.p1[1];
  s.len=Math.hypot(dx,dz); s.dir=[dx/s.len, dz/s.len]; s.ang=-Math.atan2(dz,dx);
});
const bodNaStene=(s,m)=>[ s.p1[0]+s.dir[0]*m, s.p1[1]+s.dir[1]*m ];
const ELTYPY = {
  dvere1: { nazev:'Dveře',            ic:'🚪', len:1.0 },
  dvere2: { nazev:'Dveře dvoukřídlé', ic:'🚪', len:1.9 },
  vyloha: { nazev:'Výloha (sklo)',    ic:'🪟', len:3.0, resize:[1.0,6.5] },
};
const wallRoot=new THREE.Group(), elRoot=new THREE.Group(), pickRoot=new THREE.Group();
scene.add(wallRoot); scene.add(elRoot); scene.add(pickRoot);
/* neviditelné plochy pro klikání na stěny */
Object.entries(STENY).forEach(([id,s])=>{
  const m=new THREE.Mesh(new THREE.PlaneGeometry(s.len,H),
    new THREE.MeshBasicMaterial({transparent:true,opacity:0,depthWrite:false,side:THREE.DoubleSide}));
  const mid=bodNaStene(s,s.len/2);
  m.position.set(mid[0],H/2,mid[1]); m.rotation.y=s.ang; m.userData.wall=id;
  pickRoot.add(m);
});
const ramMat=new THREE.MeshStandardMaterial({color:0x2a2a2e,roughness:0.4,metalness:0.6});
function elDvere(len,kridla){
  const g=new THREE.Group(); const vys=2.2;
  [-len/2+0.04, len/2-0.04].forEach(x=>{ const s=new THREE.Mesh(new THREE.BoxGeometry(0.08,vys,0.14),ramMat); s.position.set(x,vys/2,0); g.add(s); });
  const top=new THREE.Mesh(new THREE.BoxGeometry(len,0.1,0.14),ramMat); top.position.set(0,vys-0.05,0); g.add(top);
  if(kridla===2){ const stred=new THREE.Mesh(new THREE.BoxGeometry(0.06,vys-0.1,0.12),ramMat); stred.position.set(0,(vys-0.1)/2,0); g.add(stred);
    [-len/4,len/4].forEach((x,i)=>{ const madlo=new THREE.Mesh(new THREE.BoxGeometry(0.035,0.55,0.035),M.kov);
      madlo.position.set(x+(i?-(0.09):0.09),1.05,0.09); g.add(madlo); });
  } else { const madlo=new THREE.Mesh(new THREE.BoxGeometry(0.035,0.5,0.035),M.kov); madlo.position.set(len/2-0.2,1.0,0.09); g.add(madlo); }
  const sklo=new THREE.Mesh(new THREE.PlaneGeometry(len-0.2,vys-0.18),M.sklo); sklo.position.set(0,(vys-0.1)/2,0.02); g.add(sklo);
  return g;
}
function elVyloha(len){
  const g=new THREE.Group();
  const sokl=new THREE.Mesh(new THREE.BoxGeometry(len,0.18,0.1),M.kov); sokl.position.y=0.09; g.add(sokl);
  const horni=new THREE.Mesh(new THREE.BoxGeometry(len,0.14,0.1),M.kov); horni.position.y=H-0.07; g.add(horni);
  const sklo=new THREE.Mesh(new THREE.BoxGeometry(len-0.06,H-0.32,0.04),M.sklo); sklo.position.y=0.18+(H-0.32)/2; g.add(sklo);
  const n=Math.max(1,Math.round(len/1.6));
  for(let i=0;i<=n;i++){ const s=new THREE.Mesh(new THREE.BoxGeometry(0.06,H,0.06),M.kov); s.position.set(-len/2+len*i/n,H/2,0); g.add(s); }
  return g;
}
function rebuildSteny(){
  vycisti(wallRoot); vycisti(elRoot);
  Object.entries(STENY).forEach(([id,s])=>{
    const els=stav.steny.filter(e=>e.w===id).sort((a,b)=>a.pos-b.pos);
    let cur=0;
    els.forEach(e=>{
      const len=e.len??ELTYPY[e.t].len;
      const a=Math.max(0,e.pos-len/2), b=Math.min(s.len,e.pos+len/2);
      if(a-cur>0.01) stena(bodNaStene(s,cur),bodNaStene(s,a),M.stena,H,T,0,wallRoot);
      // prvek
      const grp=(e.t==='vyloha')?elVyloha(len):elDvere(len,e.t==='dvere2'?2:1);
      const mid=bodNaStene(s,e.pos);
      grp.position.set(mid[0],0,mid[1]); grp.rotation.y=s.ang;
      grp.userData.el=e; grp.traverse(o=>{ if(o.isMesh){o.castShadow=true;o.receiveShadow=true;} });
      elRoot.add(grp);
      if(e.t!=='vyloha') stena(bodNaStene(s,a),bodNaStene(s,b),M.stena,H-2.25,T,2.25,wallRoot); // nadpraží
      cur=b;
    });
    if(s.len-cur>0.01) stena(bodNaStene(s,cur),bodNaStene(s,s.len),M.stena,H,T,0,wallRoot);
  });
}
function volnyNaStene(w,pos,len,ignore){
  const s=STENY[w]; if(!s) return false;
  if(pos-len/2<-0.01 || pos+len/2>s.len+0.01) return false;
  return !stav.steny.some(e=>e!==ignore && e.w===w && Math.abs(e.pos-pos)<((e.len??ELTYPY[e.t].len)+len)/2-0.005);
}
/* stěna výklenku (N) i prosklený schod (VB) jsou nyní editovatelné stěny — staví je rebuildSteny() */

/* ---------- sloupy (3×, 30×30 cm, 3,1 m od levé stěny) ---------- */
