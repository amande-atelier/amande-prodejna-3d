/* mramor — tmavý se zlatavými žilkami (brand Amande) */
function mramorTex(){
  const S=512, c=document.createElement('canvas'); c.width=c.height=S; const x=c.getContext('2d');
  const g=x.createLinearGradient(0,0,S,S); g.addColorStop(0,'#17171a'); g.addColorStop(0.5,'#1f1f23'); g.addColorStop(1,'#151517');
  x.fillStyle=g; x.fillRect(0,0,S,S);
  function zilka(barva,sirka,alpha){
    x.strokeStyle=barva; x.globalAlpha=alpha; x.lineWidth=sirka; x.beginPath();
    let px=Math.random()*S, py=-20; x.moveTo(px,py);
    while(py<S+20){ const nx=px+(Math.random()-0.5)*90, ny=py+30+Math.random()*55;
      x.quadraticCurveTo(px+(Math.random()-0.5)*60, (py+ny)/2, nx, ny); px=nx; py=ny; }
    x.stroke(); x.globalAlpha=1;
  }
  for(let i=0;i<4;i++) zilka('#c5a059',1+Math.random()*1.6,0.25+Math.random()*0.3);
  for(let i=0;i<3;i++) zilka('#d8d4cc',0.7+Math.random()*1.2,0.18+Math.random()*0.22);
  for(let i=0;i<2;i++) zilka('#8a8580',3.5,0.06);
  const t=new THREE.CanvasTexture(c); t.anisotropy=8; t.colorSpace=THREE.SRGBColorSpace; return t;
}
M.mramor = new THREE.MeshStandardMaterial({ map:mramorTex(), color:0xffffff, roughness:0.16, metalness:0.05 });

/* travertin (flexibilní kamenná dýha) — světlý ivory, jemná vodorovná kresba, matný, bezespárý */
function travertinTex(){
  const W=512,Hc=512,c=document.createElement('canvas'); c.width=W; c.height=Hc; const x=c.getContext('2d');
  x.fillStyle='#e8e0d2'; x.fillRect(0,0,W,Hc);
  for(let i=0;i<70;i++){ // vodorovné jemné žilky
    const y=Math.random()*Hc, h=0.6+Math.random()*1.8, a=0.04+Math.random()*0.07;
    x.strokeStyle=`rgba(${Math.random()<0.5?'200,188,168':'247,242,232'},${a.toFixed(3)})`;
    x.lineWidth=h; x.beginPath(); let px=0,py=y; x.moveTo(0,y);
    while(px<W){ px+=20+Math.random()*40; py=y+(Math.random()-0.5)*4; x.lineTo(px,py); } x.stroke();
  }
  for(let i=0;i<1400;i++){ // jemná zrnitost / póry travertinu
    const r=Math.random(); x.fillStyle=`rgba(${r<0.5?'205,193,173':'250,246,238'},0.05)`;
    x.fillRect(Math.random()*W,Math.random()*Hc,1.3,1.3); }
  const t=new THREE.CanvasTexture(c); t.wrapS=t.wrapT=THREE.RepeatWrapping; t.anisotropy=8; t.colorSpace=THREE.SRGBColorSpace; return t;
}
M.travertin = new THREE.MeshStandardMaterial({ map:travertinTex(), color:0xffffff, roughness:0.9, metalness:0.0 });
