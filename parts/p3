    } return; }
  if(drag&&fsel&&drag.kind==='fix'){ const p=floorHit(e); if(p){ const f=fsel.data;
      let best=0,bd=1e9; stav.tracks.forEach((t,i)=>{
        const oriX=t.ori==='X', perp=oriX?Math.abs(t.a-p.z):Math.abs(t.a-p.x), along=oriX?p.x:p.z;
        const pen=perp+((along<t.od||along>t.do)?40:0); if(pen<bd){bd=pen;best=i;} });
      const staryTr=f.tr; f.tr=best;
      const t=trk(best); f.s=t.ori==='X'?p.x:p.z; clampSvNaTrack(f);
      if(staryTr!==best){ const data=f; rebuildSvetla(); fsel=liveSv.find(r=>r.data===data); vyberSvitidlo(fsel); drag={kind:'fix'}; }
