  downPt=null;
  if(painting){ painting=false; orbit.enabled=true; uloz(); return; }
  if(drag){ const byloWel=drag.kind==='wel', byloObj=drag.kind==='obj'; drag=null; orbit.enabled=true;
    if(byloWel){ rebuildSteny(); attachWselHelper(); }
    else if(byloObj&&sel&&$('autonika').checked){ const o=sel.userData.obj;
      if(TYPY[o.t].fit&&dopasujNiku(o)) vyberObjekt(prebarviObjekt(sel,o)); }
    uloz(); return; }
  if(!klik) return;
  if(mericiRezim){ const p=floorHit(e); if(p){
      if(!merA){ merA=p.clone(); tipuj('…a teď klikni na druhý bod'); }
      else { nakresliMereni(merA,p); merA=null; tipuj('Změřeno ✓ — další měření: klikni první bod (Esc = konec)'); } }
    return; }
  if(ghost) updObjGhost(e);      // dopočet z místa kliknutí — na dotykové obrazovce nepřijde pointermove
  if(svGhost) updSvGhost(e);
