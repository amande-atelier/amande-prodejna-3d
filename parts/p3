/* dopasování niky: šířku roztáhne na nejbližší mezeru (sloup ↔ stěna) podle natočení */
function dopasujNiku(o){
  const clear=0.06, COLZ=[3.5,7.1,10.7], COLX=3.1, hw=0.065;
  const alongX = Math.abs(Math.sin(o.r||0))<0.5;   // r≈0/π → šířka podél X; jinak podél Z
  let center, cands;
  if(alongX){ center=o.x; cands=[0, ROOM.celo];
    COLZ.forEach(cz=>{ if(Math.abs(cz-o.z)<0.9) cands.push(COLX-hw, COLX+hw); });
  } else { center=o.z; cands=[1.8, ROOM.hloubka];
    COLZ.forEach(cz=>cands.push(cz-hw, cz+hw)); }
  const lows=cands.filter(c=>c<center-0.02), highs=cands.filter(c=>c>center+0.02);
  const below=lows.length?Math.max(...lows):0;
  const above=highs.length?Math.min(...highs):(alongX?ROOM.celo:ROOM.hloubka);
  const gap=above-below; if(!(gap>0.6)) return false;
  o.w=Math.max(0.6, Math.min(4, gap-2*clear));
  if(alongX) o.x=+((below+above)/2).toFixed(3); else o.z=+((below+above)/2).toFixed(3);
  return true;
}
