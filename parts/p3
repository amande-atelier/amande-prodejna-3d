    const {tr,s}=svGhost.userData; const t=trk(tr), oriX=t.ori==='X';
    let tx,tz;
    if(oriX){ tz = t.a<CZ ? Math.max(0.4,t.a-1.4) : Math.min(ROOM.hloubka-0.4,t.a+1.4); tx=+Math.min(ROOM.celo-0.4,s+0.25).toFixed(2); }
