  if(svGhost){ updSvGhost(e); return; }
  if(wGhost){ updWGhost(e); return; }
  if(painting){ const p=floorHit(e); if(p) malujBod(p); return; }
  if(drag&&sel&&drag.kind==='obj'){ const p=floorHit(e); if(p){ const o=sel.userData.obj;
      [o.x,o.z]=clampObj(p.x,p.z,o.t); sel.position.set(o.x,0,o.z); selBox.update(); syncSelUI(o); } return; }
  if(drag&&wsel&&drag.kind==='wel'){ const hit=wallHit(e);
    if(hit&&hit.w===wsel.w){ const len=wsel.len??ELTYPY[wsel.t].len, s=STENY[wsel.w];
      let p=Math.max(len/2,Math.min(s.len-len/2,hit.pos));
      if(!volnyNaStene(wsel.w,p,len,wsel)){
        let nasel=null;
        for(let d=0.05; d<=1.2; d+=0.05){
          if(volnyNaStene(wsel.w,p-d,len,wsel)){ nasel=p-d; break; }
          if(volnyNaStene(wsel.w,p+d,len,wsel)){ nasel=p+d; break; } }
