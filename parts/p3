});
function updObjGhost(e){ const p=floorHit(e); if(p){ const [x,z]=clampObj(p.x,p.z,ghostTyp); ghost.visible=true; ghost.position.set(x,0,z); } }
function updSvGhost(e){ const p=floorHit(e); if(!p) return;
  let best=0,bd=1e9; stav.tracks.forEach((t,i)=>{
    const oriX=t.ori==='X', perp=oriX?Math.abs(t.a-p.z):Math.abs(t.a-p.x), along=oriX?p.x:p.z;
    const pen=perp+((along<t.od||along>t.do)?40:0); if(pen<bd){bd=pen;best=i;} });
  const t=trk(best), oriX=t.ori==='X', along=oriX?p.x:p.z;
  const s=Math.max(t.od+0.12,Math.min(t.do-0.12,along));
  svGhost.visible=true; svGhost.position.set(oriX?s:t.a,H-0.1,oriX?t.a:s); svGhost.userData={tr:best,s}; }
