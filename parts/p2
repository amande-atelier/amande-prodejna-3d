function clampSvNaTrack(f){ const t=trk(f.tr); f.s=Math.max(t.od+0.12,Math.min(t.do-0.12,f.s)); }
function rebuildTrackMeshes(){
  vycisti(trackRoot);
  stav.tracks.forEach(t=>{
    const len=Math.max(0.2,t.do-t.od), mid=(t.od+t.do)/2, oriX=t.ori==='X';
    const wx=oriX?mid:t.a, wz=oriX?t.a:mid;
    const m=new THREE.Mesh(new THREE.BoxGeometry(0.052,0.028,len),
      new THREE.MeshStandardMaterial({color:0x101013,roughness:0.5,metalness:0.5}));
    m.position.set(wx,H-0.014,wz); if(oriX) m.rotation.y=Math.PI/2; m.castShadow=true; trackRoot.add(m);
