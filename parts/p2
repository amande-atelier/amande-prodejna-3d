/* ---------- svítidla ---------- */
function vyrobSvitidlo(f){
  const def=SVITIDLA[f.t];
  const t=trk(f.tr), oriX=t.ori==='X';
  const [wx0,wz0]=svWorld(f);
  const grp=new THREE.Group(); grp.position.set(wx0, H-0.028, wz0);
  grp.userData.fix=f;
  const adapterMat=new THREE.MeshStandardMaterial({color:0x141417,roughness:0.45,metalness:0.6});
  const emisMat=new THREE.MeshStandardMaterial({color:0xffffff,emissive:0xffffff,emissiveIntensity:1.6});
  const emis=[];
  let light=null, target=null;

  if(f.t==='spot'||f.t==='zoom'){
    const ad=new THREE.Mesh(new THREE.BoxGeometry(0.034,0.018,0.16),adapterMat); ad.position.y=-0.009;
    if(oriX) ad.rotation.y=Math.PI/2; grp.add(ad);
    const stem=new THREE.Mesh(new THREE.CylinderGeometry(0.011,0.011,0.07,10),adapterMat); stem.position.y=-0.053; grp.add(stem);
    const R=f.t==='zoom'?0.0325:0.0225, L=f.t==='zoom'?0.135:0.10;
    const bodyG=new THREE.Group(); bodyG.position.y=-0.095; grp.add(bodyG);
    const geo=new THREE.CylinderGeometry(R,R,L,20); geo.rotateX(Math.PI/2);
    const body=new THREE.Mesh(geo,adapterMat); bodyG.add(body);
    if(f.t==='zoom'){ const ring=new THREE.Mesh(new THREE.CylinderGeometry(R+0.005,R+0.005,0.03,20).rotateX(Math.PI/2),M.cernyKov); ring.position.z=-L/2+0.02; bodyG.add(ring); }
    const lensGeo=new THREE.CircleGeometry(R*0.8,18); const lens=new THREE.Mesh(lensGeo,emisMat);
    lens.position.z=-L/2-0.002; lens.rotation.y=Math.PI; bodyG.add(lens); emis.push(emisMat);
    grp.userData.bodyG=bodyG;
    light=new THREE.SpotLight(0xffffff,1,0,1,0.45,1.5);
    target=new THREE.Object3D();
  }
  else if(f.t==='grille'||f.t==='diff'||f.t==='flood'){
    if(oriX) grp.rotation.y=Math.PI/2;   // lineární modul leží podél tracku
    const len=f.t==='flood'?0.6:0.22;
    const telo=new THREE.Mesh(new THREE.BoxGeometry(0.022,0.026,len),adapterMat); telo.position.y=-0.013; grp.add(telo);
    if(f.t==='grille'){
      for(let i=0;i<Math.round(len/0.022);i++){
        const b=new THREE.Mesh(new THREE.PlaneGeometry(0.014,0.014),emisMat);
        b.rotation.x=Math.PI/2; b.position.set(0,-0.0272,-len/2+0.014+i*0.022); grp.add(b); }
    } else {
      const pas=new THREE.Mesh(new THREE.PlaneGeometry(0.016,len-0.02),emisMat);
      pas.rotation.x=Math.PI/2; pas.position.y=-0.0272; grp.add(pas);
    }
    emis.push(emisMat);
    light=new THREE.SpotLight(0xffffff,1,0,1,0.6,1.4);
    target=new THREE.Object3D();
  }
  else if(f.t==='pendant'){
    const drop=f.drop??1.2;
    const ad=new THREE.Mesh(new THREE.BoxGeometry(0.034,0.018,0.12),adapterMat); ad.position.y=-0.009;
    if(oriX) ad.rotation.y=Math.PI/2; grp.add(ad);
    const lanko=new THREE.Mesh(new THREE.CylinderGeometry(0.002,0.002,drop,6),M.cernyMat); lanko.position.y=-drop/2; grp.add(lanko);
    const koule=new THREE.Mesh(new THREE.SphereGeometry(0.05,22,18),emisMat); koule.position.y=-drop-0.05; grp.add(koule);
    const cepicka=new THREE.Mesh(new THREE.SphereGeometry(0.052,22,10,0,Math.PI*2,0,Math.PI/2.7),adapterMat);
    cepicka.position.y=-drop-0.05; grp.add(cepicka);
    emis.push(emisMat);
    light=new THREE.PointLight(0xffffff,1,7,1.7);
    light.position.y=-drop-0.05;
  }
  grp.traverse(o=>{ if(o.isMesh) o.castShadow=false; });
  svRoot.add(grp);
  if(light){ grp.add(light); }
  if(target){ scene.add(target); light.target=target; }
  const rec={data:f,grp,light,target,emis};
  liveSv.push(rec); aktualizujSvitidlo(rec);
  return rec;
}
function aktualizujSvitidlo(rec){
  const f=rec.data, def=SVITIDLA[f.t];
  const [wx,wz]=svWorld(f);
  rec.grp.position.set(wx,H-0.028,wz);
  const barva=kelvinRGB(f.k);
  rec.emis.forEach(m=>{ m.emissive.copy(barva); m.color.copy(barva); m.emissiveIntensity=0.4+1.6*f.dim; });
  if(!rec.light) return;
  const I=def.base*f.dim*stav.gmult;
  rec.light.color.copy(barva);
  if(rec.light.isSpotLight){
    const beam=f.t==='zoom'?(f.ang??36):def.beam;
    rec.light.angle=Math.min(Math.PI/2.05, beam*Math.PI/360);
    rec.light.intensity=I; rec.light.distance=13; rec.light.decay=1.5;
    let ax=f.tx, az=f.tz;
    if(!def.aim){ ax=wx; az=wz; }
    if(Math.abs(ax-wx)<0.02 && Math.abs(az-wz)<0.02) az+=0.02;
    rec.target.position.set(ax,0,az);
  } else {
    rec.light.intensity=I; rec.light.position.y=-(f.drop??1.2)-0.05;
    // posun lanka+koule při změně závěsu => nejjednodušší rebuild
  }
}
function rebuildSvetla(){
  liveSv.forEach(r=>{ if(r.target) scene.remove(r.target); });
  liveSv.length=0;
  vycisti(svRoot);
  stav.svetla.forEach(f=>vyrobSvitidlo(f));
}

