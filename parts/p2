function vychoziStav(){
  stav.cine=true; // reál: strop přemalovaný načerno
  stav.stenaC=0xeceef0;
  stav.tracks=[
    {ori:'Z',a:1.0,od:2.0,do:13.0},    // tr0 ulička – u levé zdi (regál)
    {ori:'Z',a:2.7,od:3.0,do:11.0},    // tr1 ulička – u nika-stěny (věšáky)
    {ori:'Z',a:4.4,od:1.0,do:14.8},    // tr2 retail – u niky
    {ori:'Z',a:6.2,od:1.0,do:14.8},    // tr3 retail – střed
    {ori:'Z',a:8.0,od:1.0,do:14.8},    // tr4 retail – u pravé stěny/výlohy
    {ori:'X',a:1.1,od:3.6,do:8.6},     // tr5 příčná – čelní výloha + vstup
    {ori:'X',a:15.0,od:0.5,do:8.6}     // tr6 příčná – podél stěny se dvěma dveřmi
  ]; stav.denni=1.0; stav.gmult=1.1;
  stav.objekty=[ {t:'pultdl',x:4.48,z:5.31,r:Math.PI/2}, {t:'pultkr',x:4.1,z:3.66,r:0}, {t:'gaucRoh',x:7.0,z:4.6,r:Math.PI,c:3},
    {t:'stender',x:5.2,z:6.6,r:0}, {t:'gondola',x:5.4,z:9.4,r:0},
    {t:'regal',x:0.3,z:6.0,r:-Math.PI/2}, {t:'regal',x:0.3,z:9.0,r:-Math.PI/2},
    {t:'figurina',x:4.4,z:5.0,r:-0.4}, {t:'taburet',x:6.6,z:6.2,r:0,c:4}, {t:'rostlina',x:0.5,z:14.8,r:0} ];
  stav.steny=defaultSteny();
  stav.svetla=[];
  const P=(t,tr,s,tx,tz,ang)=>{ const o={t,tr,s:+(+s).toFixed(2),tx,tz,k:3000,dim:(t==='diff'?0.9:1.0)}; if(ang)o.ang=ang; stav.svetla.push(o); };
  const PEND=(tr,s)=> stav.svetla.push({t:'pendant',tr,s:+(+s).toFixed(2),tx:0,tz:0,k:3000,dim:1.0,drop:1.3});
  const lin=(a,b,n)=>Array.from({length:n},(_,i)=>+(a+i*(b-a)/(n-1)).toFixed(2));
  // tr0 ulička – regál u levé zdi: 10× bodovka 12W (na zeď)
  lin(2.4,12.6,10).forEach(s=> P('spot',0,s,0.2,s));
  // tr1 ulička – věšáky: 8× bodovka 12W (na nika-stěnu)
  lin(3.3,10.7,8).forEach(s=> P('spot',1,s,2.9,s));
  // tr2 retail u niky: 6× spot 12W (na niku) + 6× difuz + 1 zoom
  lin(1.2,14.6,12).forEach((s,i)=> (i%2===0) ? P('spot',2,s,3.6,s) : P('diff',2,s,4.4,s));
  P('zoom',2,8.0,3.4,8.0,30);
  // tr3 retail střed: 6× spot 15W (akcent) + 8× difuz (ambient)
  lin(2.0,14.2,6).forEach(s=> P('spot',3,s,6.2,s));
  lin(1.2,14.6,8).forEach(s=> P('diff',3,s,6.2,s));
  // tr4 retail pravá: 6× spot 12W (na pravou stěnu) + 6× difuz + 1 zoom
  lin(1.2,14.6,12).forEach((s,i)=> (i%2===0) ? P('spot',4,s,8.4,s) : P('diff',4,s,7.8,s));
  P('zoom',4,8.0,8.5,8.0,30);
  // tr5 čelní výloha: 4× zoom (hero) + 4× spot 15W (display)
  lin(4.0,8.4,8).forEach((s,i)=> (i%2===0) ? P('zoom',5,s,s,0.2,30) : P('spot',5,s,s,0.2));
  // tr6 stěna se dveřmi: 4× spot 12W + 4× difuz
  lin(1.0,8.4,8).forEach((s,i)=> (i%2===0) ? P('spot',6,s,s,15.3) : P('diff',6,s,s,15.0));
  // DESIGNOVÉ závěsné koule (Pendant Ball E100-7BP) nad loungem a pultem
  PEND(4,4.6); PEND(3,4.6); PEND(3,12.2);
  PRESETY.vinyl();
}
function serializuj(){
  return JSON.stringify({ v:6, cine:stav.cine, tracks:stav.tracks, objekty:stav.objekty,
    svetla:stav.svetla, steny:stav.steny, podlaha:Array.from(stav.podlaha), denni:stav.denni, gmult:stav.gmult,
    stenaC:stav.stenaC });
}
function aplikuj(json){
  try{
    const d=JSON.parse(json);
    // migrace: v2 tracky čísla (x) → v3 {x,z0,z1} → v5 {ori,a,od,do}; svítidla f.z → f.s
    stav.tracks=(d.tracks&&d.tracks.length?d.tracks:[2.5,6]).slice(0,8).map(t=>{
      if(typeof t==='number') return {ori:'Z',a:t,od:1.2,do:17.3};
      if(t.ori) return {ori:t.ori==='X'?'X':'Z', a:+t.a||2.5, od:+t.od||1.2, do:+t.do||17.3};
      return {ori:'Z', a:+t.x||2.5, od:+t.z0||1.2, do:+t.z1||17.3};
    });
    stav.tracks.forEach(t=>{ const o=trOsy(t);
      t.a=Math.max(o.aMin,Math.min(o.aMax,t.a));
      t.od=Math.max(o.sMin,Math.min(o.sMax,t.od)); t.do=Math.max(o.sMin,Math.min(o.sMax,t.do));
      if(t.do-t.od<TR_DMIN) t.do=Math.min(o.sMax,t.od+TR_DMIN); });
    stav.cine=(d.v>=3)?!!d.cine:true;
    stav.objekty=(d.objekty||[]).filter(o=>TYPY[o.t]);
    stav.objekty.forEach(o=>{ const def=TYPY[o.t];
      if(def.resize){ if(o.w!=null) o.w=Math.max(def.resize[0],Math.min(def.resize[1],+o.w||def.w)); }
      else delete o.w; });
    stav.stenaC=(typeof d.stenaC==='number')?d.stenaC:0xeceef0;
    stav.svetla=(d.svetla||[]).filter(f=>SVITIDLA[f.t]&&f.tr<stav.tracks.length);
    stav.svetla.forEach(f=>{ if(f.s==null) f.s=+f.z||0; delete f.z; clampSvNaTrack(f); });
    stav.steny=Array.isArray(d.steny)
      ? d.steny.filter(e=>ELTYPY[e.t]&&STENY[e.w]).map(e=>({t:e.t,w:e.w,pos:+e.pos||0,len:+e.len||ELTYPY[e.t].len}))
      : defaultSteny(); // migrace v<4 (a smazání starých bočních dveří — nebyly v datech, byly natvrdo)
    if(d.podlaha&&d.podlaha.length===FC*FR) stav.podlaha.set(d.podlaha);
    stav.denni=d.denni??1; stav.gmult=d.gmult??1;
    return true;
  }catch(e){ console.warn('Import selhal',e); return false; }
}
let saveTimer=null;
function uloz(hned=false){
  if(saveTimer) clearTimeout(saveTimer);
  const fn=()=>{ try{ localStorage.setItem(KLIC,serializuj()); }catch(e){} aktualizujStats(); zapisHistorii(); };
  hned?fn():saveTimer=setTimeout(fn,700);
}

/* ---------- historie změn (zpět / vpřed) ---------- */
const HIST_MAX=60;
let hist=[], histI=-1, obnovujiHist=false;
function zapisHistorii(){
  if(obnovujiHist) return;
  const sn=serializuj();
  if(hist[histI]===sn) return;
  hist=hist.slice(0,histI+1); hist.push(sn);
  if(hist.length>HIST_MAX) hist.shift();
  histI=hist.length-1; aktualizujUndoUI();
}
function obnovZHistorie(){
  obnovujiHist=true;
  zrusRezimy();
  aplikuj(hist[histI]); obnovVse();
  try{ localStorage.setItem(KLIC,hist[histI]); }catch(e){}
  aktualizujStats();
  obnovujiHist=false; aktualizujUndoUI();
}
function flushUloz(){ if(saveTimer){ clearTimeout(saveTimer); saveTimer=null;
  try{ localStorage.setItem(KLIC,serializuj()); }catch(e){} zapisHistorii(); } }
function undoKrok(){ flushUloz(); if(histI>0){ histI--; obnovZHistorie(); } }
function redoKrok(){ flushUloz(); if(histI<hist.length-1){ histI++; obnovZHistorie(); } }
function aktualizujUndoUI(){ const u=document.getElementById('btnUndo'), r=document.getElementById('btnRedo');
  if(u) u.disabled=histI<=0; if(r) r.disabled=histI>=hist.length-1; }

